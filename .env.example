# Store the Firebase service-account JSON outside this repository.
FIREBASE_CREDENTIALS_FILE=C:\secure\ultracoachmatrix\firebase-service-account.json
FIREBASE_PROJECT_ID=push-notification-ucm-producti
PUSH_NOTIFICATIONS_ENABLED=true

# Add your computer LAN IP here when testing Flutter on a physical phone.
# Example: DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,10.0.3.2,192.168.1.10
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,10.0.2.2,10.0.3.2,testserver

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=UltraCoachMatrix <your-email@example.com>
EMAIL_REPLY_TO=your-email@example.com
EMAIL_BASE_URL=https://ultracoachmatrix.in
# Optional overrides. By default the bundled static/apk/Ultra Coach Matrix.apk is used.
STUDENT_APP_DOWNLOAD_URL=
STUDENT_APP_APK_PATH=
EMAIL_NOTIFICATIONS_RUN_SYNC=false

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
BACKGROUND_JOB_SYNC_NOTICE_FALLBACK=true
